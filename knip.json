{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/quick-pane-main.tsx"],
  "ignoreIssues": {
    "src/lib/recovery.ts": ["exports"],
    "src/lib/tauri-bindings.ts": ["exports"]
  },
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/components/ui/**",
    "**/index.ts",
    "src/lib/platform-strings.ts"
  ],
  "ignoreDependencies": [
    "@tauri-apps/*",
    "@radix-ui/*",
    "tailwindcss",
    "tw-animate-css",
    "react-day-picker",
    "@testing-library/*"
  ],
  "ignoreExportsUsedInFile": true
}
